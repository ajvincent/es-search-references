{
  "compilerOptions": {
    "lib": [
      "ES2024",
      "ESNext.Collection",
      /*
      "ESNext.Object",
      "ESNext.Promise",
      */
      "DOM"
    ],
    "module": "NodeNext",
    "target": "ES2024",
    "moduleResolution": "NodeNext",
    "strict": true,
    "sourceMap": false,
    "declaration": false,

    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "../docs"
  },

  "include": [
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],

  "extends": "@tsconfig/node22/tsconfig.json"
}
