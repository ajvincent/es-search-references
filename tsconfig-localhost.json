{
  "compilerOptions": {
    "lib": [
      "ES2024",
      "ESNext.AsyncIterable",
      "ESNext.Iterator"
    ],
    "module": "NodeNext",
    "target": "ES2024",
    "moduleResolution": "NodeNext",
    "strict": true,
    "sourceMap": false,
    "declaration": false,

    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "types": [
      "node",
    ]
  },

  "include": [
    "fixtures/**/*.ts",
    "reference-spec/**/*.ts",
    "source/localhost/*.ts",
    "source/updates/*.ts",
  ],

  "paths": {
    "#build-utilities/*": "./build-utilities/*"
  },

  "extends": "@tsconfig/node24/tsconfig.json"
}
